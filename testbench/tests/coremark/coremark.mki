OFILES = crt0.o core_main.o core_list_join.o core_matrix.o core_state.o core_util.o core_portme.o ee_printf.o printf.o
TEST_CFLAGS = -g -O3

COREMARK_FLAGS_STR := -g -O3
TEST_CFLAGS += -DFLAGS_STR="\"$(COREMARK_FLAGS_STR)\""
TEST_CFLAGS += -I$(TEST_DIR)

TEST_CFLAGS += -DHAS_FLOAT=0
TEST_CFLAGS += -DHAS_TIME_H=0
TEST_CFLAGS += -DUSE_CLOCK=0
TEST_CFLAGS += -DHAS_STDIO=0
TEST_CFLAGS += -DHAS_PRINTF=0

# DITERATIONS > 40 * DEE_TICKS_PER_SEC
TEST_CFLAGS += -DEE_TICKS_PER_SEC=1000000
TEST_CFLAGS += -DITERATIONS=50
TEST_CFLAGS += -DSCALE=1000  